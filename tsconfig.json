{
  // This file is not used in compilation. It is here just for a nice editor experience.
  // The compilerOptions inline @docusaurus/tsconfig (minus its baseUrl, which
  // TypeScript 7 removed) with our own additions at the end.
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "paths": {
      "@site/*": ["./*"],
      "*": ["./*"]
    },
    "skipLibCheck": true,
    "strict": false,
    "plugins": [{ "name": "typescript-plugin-css-modules" }],
    "types": ["docusaurus-plugin-sass"]
  },
  "include": ["sidebars.ts", "docusaurus.config.ts", "src"]
}
